# Copy this file to .env and fill in your own keys. Never commit the real .env.

# --- Required ---
GROQ_API_KEY=            # groq.com — AI caption writer
INSTAGRAM_ACCESS_TOKEN=  # Meta Developer — Instagram API (Instagram login) token
INSTAGRAM_USER_ID=       # Your Instagram user id (graph.instagram.com/me)
PORT=3001

# --- Optional ---
HF_API_KEY=              # huggingface.co — AI slide-2 backgrounds (falls back to photo if unset)

# Auto-posting is OFF by default. Set AUTO_START=true (e.g. on Render) to start
# the scheduler on boot. Leave unset locally to avoid surprise posts.
AUTO_START=

# Schedule used when AUTO_START=true. Peak Instagram engagement is ~lunchtime
# and evening, so this posts twice a day at 12:00 and 19:00 (every ~12h).
DEFAULT_CRON=0 12,19 * * *

# Timezone for the schedule above. REQUIRED for peak hours to be correct on the
# cloud (servers default to UTC). Use an IANA name, e.g. America/Toronto,
# America/New_York, Asia/Kolkata, Europe/London.
SCHEDULE_TZ=

# Supabase — optional. Only used to remember already-posted articles across
# restarts (dedup). The bot works fine without it.
SUPABASE_URL=
SUPABASE_ANON_KEY=
